<Window x:Class="LinguaFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LinguaFlow"
        MinHeight="680"
        MinWidth="1080"
        Height="740"
        Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Style="{StaticResource CommandBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="LinguaFlow"
                           Style="{StaticResource AppTitleStyle}" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Command="{Binding NewDocumentCommand}"
                            Content="New"
                            Style="{StaticResource CommandButtonStyle}" />
                    <Button Command="{Binding OpenDocumentCommand}"
                            Content="Open"
                            Style="{StaticResource CommandButtonStyle}" />
                    <Button Command="{Binding SaveDocumentCommand}"
                            Content="Save"
                            Style="{StaticResource CommandButtonStyle}" />
                    <Button Command="{Binding ExportDocxCommand}"
                            Content="DOCX"
                            Style="{StaticResource CommandButtonStyle}" />
                    <Button Command="{Binding ExportPdfCommand}"
                            Content="PDF"
                            Style="{StaticResource CommandButtonStyle}" />
                    <Button Command="{Binding CopyTranslationCommand}"
                            Content="Copy"
                            Style="{StaticResource CommandButtonStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal">
                    <TextBlock Text="Engine"
                               Style="{StaticResource CommandLabelStyle}" />
                    <ComboBox Width="132"
                              ItemsSource="{Binding TranslationEngines}"
                              SelectedItem="{Binding SelectedTranslationEngine}"
                              Style="{StaticResource CommandComboBoxStyle}" />
                    <TextBlock Text="To"
                               Style="{StaticResource CommandLabelStyle}" />
                    <ComboBox Width="112"
                              IsEnabled="False"
                              SelectedIndex="0"
                              Style="{StaticResource CommandComboBoxStyle}">
                        <ComboBoxItem Content="Spanish" />
                    </ComboBox>
                    <TextBlock Text="Model"
                               Style="{StaticResource CommandLabelStyle}" />
                    <ComboBox Width="178"
                              ItemsSource="{Binding AvailableModels}"
                              SelectedItem="{Binding SelectedModel}"
                              IsEnabled="{Binding IsOllamaSelected}"
                              Style="{StaticResource CommandComboBoxStyle}" />
                    <Button Command="{Binding OpenSettingsCommand}"
                            Content="Settings"
                            Style="{StaticResource CommandButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom"
                   Style="{StaticResource MainStatusBarStyle}">
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedTranslationEngine, StringFormat=Engine: {0}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedModel, StringFormat=Model: {0}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding TranslationStatus}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding LatencyDisplay}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding WordCount, StringFormat=Words: {0}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding CharacterCount, StringFormat=Characters: {0}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding TokenUsageDisplay}" />
            </StatusBarItem>
        </StatusBar>

        <Grid Style="{StaticResource WorkspaceStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="430" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" MinWidth="430" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource EditorPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Style="{StaticResource PaneHeaderStyle}">
                        <TextBlock Text="English"
                                   Style="{StaticResource PaneTitleStyle}" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="Draft"
                                   Style="{StaticResource PaneBadgeStyle}" />
                    </DockPanel>

                    <RichTextBox Grid.Row="1"
                                 Style="{StaticResource DocumentEditorStyle}"
                                 Background="{StaticResource EditorBackgroundBrush}"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 AcceptsTab="True"
                                 SpellCheck.IsEnabled="True">
                        <FlowDocument PagePadding="0"
                                      ColumnWidth="999999">
                            <Paragraph Foreground="{StaticResource MutedTextBrush}">
                                Start writing in English here.
                            </Paragraph>
                        </FlowDocument>
                    </RichTextBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="16"
                          HorizontalAlignment="Stretch"
                          Background="Transparent" />

            <Border Grid.Column="2"
                    Style="{StaticResource EditorPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Style="{StaticResource PaneHeaderStyle}">
                        <TextBlock Text="Spanish"
                                   Style="{StaticResource PaneTitleStyle}" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="Preview"
                                   Style="{StaticResource PaneBadgeStyle}" />
                    </DockPanel>

                    <RichTextBox Grid.Row="1"
                                 Style="{StaticResource DocumentEditorStyle}"
                                 IsReadOnly="True"
                                 Background="{StaticResource TranslationBackgroundBrush}">
                        <FlowDocument PagePadding="0"
                                      ColumnWidth="999999">
                            <Paragraph Foreground="{StaticResource MutedTextBrush}">
                                Translation preview will appear here when translation services are connected.
                            </Paragraph>
                        </FlowDocument>
                    </RichTextBox>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
