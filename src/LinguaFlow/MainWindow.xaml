<Window x:Class="LinguaFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LinguaFlow"
        MinHeight="720"
        MinWidth="1120"
        Height="760"
        Width="1220"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <DockPanel LastChildFill="True">
        <ToolBarTray DockPanel.Dock="Top"
                     Background="{StaticResource ToolbarBackgroundBrush}">
            <ToolBar Style="{StaticResource MainToolBarStyle}">
                <Button Command="{Binding NewDocumentCommand}"
                        Content="New"
                        Style="{StaticResource ToolbarButtonStyle}" />
                <Button Command="{Binding OpenDocumentCommand}"
                        Content="Open"
                        Style="{StaticResource ToolbarButtonStyle}" />
                <Button Command="{Binding SaveDocumentCommand}"
                        Content="Save"
                        Style="{StaticResource ToolbarButtonStyle}" />
                <Separator />
                <Button Command="{Binding ExportDocxCommand}"
                        Content="Export DOCX"
                        Style="{StaticResource ToolbarButtonStyle}" />
                <Button Command="{Binding ExportPdfCommand}"
                        Content="Export PDF"
                        Style="{StaticResource ToolbarButtonStyle}" />
                <Button Command="{Binding CopyTranslationCommand}"
                        Content="Copy Translation"
                        Style="{StaticResource ToolbarButtonStyle}" />
                <Separator />
                <TextBlock Text="Engine"
                           Style="{StaticResource ToolbarLabelStyle}" />
                <ComboBox Width="150"
                          ItemsSource="{Binding TranslationEngines}"
                          SelectedItem="{Binding SelectedTranslationEngine}"
                          Style="{StaticResource ToolbarComboBoxStyle}" />
                <TextBlock Text="Language"
                           Style="{StaticResource ToolbarLabelStyle}" />
                <ComboBox Width="130"
                          IsEnabled="False"
                          SelectedIndex="0"
                          Style="{StaticResource ToolbarComboBoxStyle}">
                    <ComboBoxItem Content="Spanish" />
                </ComboBox>
                <TextBlock Text="Model"
                           Style="{StaticResource ToolbarLabelStyle}" />
                <ComboBox Width="190"
                          ItemsSource="{Binding AvailableModels}"
                          SelectedItem="{Binding SelectedModel}"
                          IsEnabled="{Binding IsOllamaSelected}"
                          Style="{StaticResource ToolbarComboBoxStyle}" />
                <Separator />
                <Button Command="{Binding OpenSettingsCommand}"
                        Content="Settings"
                        Style="{StaticResource ToolbarButtonStyle}" />
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom"
                   Style="{StaticResource MainStatusBarStyle}">
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedTranslationEngine, StringFormat=Engine: {0}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedModel, StringFormat=Model: {0}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding TranslationStatus}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding LatencyDisplay}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding WordCount, StringFormat=Words: {0}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding CharacterCount, StringFormat=Characters: {0}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding TokenUsageDisplay}" />
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="430" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" MinWidth="430" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource EditorPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Style="{StaticResource PaneHeaderStyle}">
                        <TextBlock Text="English"
                                   Style="{StaticResource PaneTitleStyle}" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="Draft"
                                   Style="{StaticResource PaneBadgeStyle}" />
                    </DockPanel>

                    <RichTextBox Grid.Row="1"
                                 BorderThickness="0"
                                 Background="{StaticResource EditorBackgroundBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 FontFamily="Segoe UI"
                                 FontSize="15"
                                 Padding="22"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsTab="True"
                                 SpellCheck.IsEnabled="True">
                        <FlowDocument PagePadding="0"
                                      ColumnWidth="999999">
                            <Paragraph Foreground="{StaticResource MutedTextBrush}">
                                Start writing in English here.
                            </Paragraph>
                        </FlowDocument>
                    </RichTextBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="16"
                          HorizontalAlignment="Stretch"
                          Background="Transparent" />

            <Border Grid.Column="2"
                    Style="{StaticResource EditorPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Style="{StaticResource PaneHeaderStyle}">
                        <TextBlock Text="Spanish"
                                   Style="{StaticResource PaneTitleStyle}" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="Preview"
                                   Style="{StaticResource PaneBadgeStyle}" />
                    </DockPanel>

                    <RichTextBox Grid.Row="1"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="{StaticResource TranslationBackgroundBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 FontFamily="Segoe UI"
                                 FontSize="15"
                                 Padding="22"
                                 VerticalScrollBarVisibility="Auto">
                        <FlowDocument PagePadding="0"
                                      ColumnWidth="999999">
                            <Paragraph Foreground="{StaticResource MutedTextBrush}">
                                Translation preview will appear here when translation services are connected.
                            </Paragraph>
                        </FlowDocument>
                    </RichTextBox>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
