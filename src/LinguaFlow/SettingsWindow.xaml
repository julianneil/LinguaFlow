<Window x:Class="LinguaFlow.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        MinWidth="560"
        MinHeight="640"
        Width="620"
        Height="680"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="18"
            Padding="20"
            Background="{StaticResource ChromeBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="4">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Command="{Binding CancelCommand}"
                        Content="Cancel"
                        Style="{StaticResource CommandButtonStyle}" />
                <Button Command="{Binding SaveCommand}"
                        Content="Save"
                        Style="{StaticResource PrimaryCommandButtonStyle}" />
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="Settings"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Margin="0,0,0,18" />

                    <TextBlock Text="Translation"
                               Style="{StaticResource SettingsSectionTitleStyle}" />
                    <Grid Style="{StaticResource SettingsGridStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Text="Mode" Style="{StaticResource SettingsLabelStyle}" />
                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  ItemsSource="{Binding TranslationModes}"
                                  SelectedItem="{Binding SelectedTranslationMode}" />

                        <TextBlock Grid.Row="1" Text="Engine" Style="{StaticResource SettingsLabelStyle}" />
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding TranslationEngines}"
                                  SelectedItem="{Binding SelectedTranslationEngine}" />

                        <TextBlock Grid.Row="2" Text="Style" Style="{StaticResource SettingsLabelStyle}" />
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  ItemsSource="{Binding TranslationStyles}"
                                  SelectedItem="{Binding SelectedTranslationStyle}" />
                    </Grid>

                    <TextBlock Text="Ollama"
                               Style="{StaticResource SettingsSectionTitleStyle}" />
                    <Grid Style="{StaticResource SettingsGridStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Text="Endpoint" Style="{StaticResource SettingsLabelStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding OllamaEndpoint, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" Text="Model" Style="{StaticResource SettingsLabelStyle}" />
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding AvailableModels}"
                                  SelectedItem="{Binding SelectedModel}" />

                        <TextBlock Grid.Row="2" Text="Reminder" Style="{StaticResource SettingsLabelStyle}" />
                        <CheckBox Grid.Row="2" Grid.Column="1"
                                  Content="Notify me when Ollama is not running"
                                  IsChecked="{Binding NotifyWhenOllamaUnavailable}" />
                    </Grid>

                    <TextBlock Text="Editor"
                               Style="{StaticResource SettingsSectionTitleStyle}" />
                    <Grid Style="{StaticResource SettingsGridStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Text="Live delay (ms)" Style="{StaticResource SettingsLabelStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding DebounceDelayMilliseconds, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" Text="Font size" Style="{StaticResource SettingsLabelStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
