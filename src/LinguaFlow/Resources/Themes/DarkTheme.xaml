<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#171717</Color>
    <Color x:Key="SurfaceColor">#232323</Color>
    <Color x:Key="SurfaceAltColor">#2C2C2C</Color>
    <Color x:Key="EditorBackgroundColor">#FAFAF7</Color>
    <Color x:Key="TranslationBackgroundColor">#F3F6F4</Color>
    <Color x:Key="PrimaryTextColor">#1D1D1B</Color>
    <Color x:Key="ChromeTextColor">#F1F1EA</Color>
    <Color x:Key="MutedTextColor">#74746E</Color>
    <Color x:Key="BorderColor">#3D3D38</Color>
    <Color x:Key="AccentColor">#2AA198</Color>
    <Color x:Key="AccentAltColor">#B58900</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="{StaticResource EditorBackgroundColor}" />
    <SolidColorBrush x:Key="TranslationBackgroundBrush" Color="{StaticResource TranslationBackgroundColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="ChromeTextBrush" Color="{StaticResource ChromeTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentAltBrush" Color="{StaticResource AccentAltColor}" />

    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="MainToolBarStyle" TargetType="ToolBar">
        <Setter Property="Background" Value="{StaticResource ToolbarBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ChromeTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Padding" Value="10,8" />
    </Style>

    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ChromeTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="ToolbarLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ChromeTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="12,0,6,0" />
    </Style>

    <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="0,0,4,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="EditorPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource EditorBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="PaneHeaderStyle" TargetType="DockPanel">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="LastChildFill" Value="True" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style x:Key="PaneTitleStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ChromeTextBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="16,12" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PaneBadgeStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ChromeTextBrush}" />
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Padding" Value="9,3" />
        <Setter Property="Margin" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="MainStatusBarStyle" TargetType="StatusBar">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ChromeTextBrush}" />
        <Setter Property="Padding" Value="10,4" />
    </Style>
</ResourceDictionary>
